%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!129 &1
PlayerSettings:
  productName: CoinBattle Saki
  companyName: Cryptarena
  defaultScreenWidth: 1080
  defaultScreenHeight: 1920
  defaultIsNativeResolution: 0
  defaultScreenOrientation: 1  # Portrait
  allowedAutorotateToPortrait: 1
  allowedAutorotateToPortraitUpsideDown: 0
  allowedAutorotateToLandscapeLeft: 0
  allowedAutorotateToLandscapeRight: 0
  useAnimatedAutorotation: 1
  colorSpace: 1  # Linear
  bundleVersion: 0.1.0
  applicationIdentifier:
    Android: com.cryptarena.coinbattlesaki
    iPhone: com.cryptarena.coinbattlesaki
  targetDevice: 2  # iPhone + iPad
  targetSdkVersion: 0  # Latest
  minSdkVersion: 26  # Android 8.0+
  statusBarHidden: 1
  renderingPath: 1  # Forward
  graphicsJobs: 1
  openGLRequireES31: 0
  openGLRequireES31AEP: 0
  openGLRequireES32: 0
